# ハッシュ付きアセット（JS/CSS）: 1年キャッシュ（速度優先）
<IfModule mod_headers.c>
  <FilesMatch "\.(js|css)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # index.html: 常に最新を確認（更新反映優先）
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache"
  </FilesMatch>

  # 画像・フォント: 1週間キャッシュ
  <FilesMatch "\.(png|jpg|jpeg|gif|svg|ico|webp|woff2?)$">
    Header set Cache-Control "public, max-age=604800"
  </FilesMatch>
</IfModule>
